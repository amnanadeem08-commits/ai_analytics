# Example environment variables for AI Analytics Assistant
# Copy this file to .env and replace placeholders with your real keys.

# Choose provider: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic key (example placeholder)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI key (example placeholder)
OPENAI_API_KEY=your_openai_api_key_here

# Model and limits
AI_MODEL=claude-opus-4-5
AI_MAX_TOKENS=2048

# Other optional settings
MAX_UPLOAD_MB=50
